# Database
DB_NAME=familyplanner
DB_USER=familyplanner
DB_PASSWORD=familyplanner

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Auth (OIDC)
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI=http://localhost:8180/realms/familyplanner
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_JWK_SET_URI=http://keycloak:8080/realms/familyplanner/protocol/openid-connect/certs

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Frontend OIDC
VITE_OIDC_AUTHORITY=http://localhost:8180/realms/familyplanner
VITE_OIDC_CLIENT_ID=familyplanner-frontend
VITE_OIDC_REDIRECT_URI=http://localhost:3000/callback
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:3000/login

# Server Ports
SERVER_PORT=8081
